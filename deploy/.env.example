# FreeLLMAPI — Viewport internal overlay env
# Copy to .env and fill in. Placeholders only — NEVER commit real secrets.

# MANDATORY: 64-char hex string used to encrypt stored provider credentials.
# Generate with: openssl rand -hex 32
ENCRYPTION_KEY=

# Port the service listens on inside the container (also the loopback host port).
PORT=3001

# Optional:
# NODE_ENV=production
